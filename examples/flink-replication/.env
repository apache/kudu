# Kudu Replication Demo — default environment variables.
# Edit this file to change defaults, or export a variable in your shell
# before running make/docker compose to override a single value.

# Apache Kudu image tag. Use a specific version (e.g. 1.18.1-ubuntu) to pin the demo
# to a known-good release; 'latest' always pulls the newest available image.
KUDU_VERSION=1.18.1-ubuntu

# Apache Kudu Python client image tag used by the ingest simulator.
KUDU_PYTHON_VERSION=kudu-python-1.18.1-ubuntu

# Flink image tag.  Pinned to 1.19.x because the kudu-replication job JAR is
# built against Flink 1.19.
FLINK_VERSION=1.19.2-java17

# Observability image tags.
PROMETHEUS_VERSION=v3.10.0
JSON_EXPORTER_VERSION=v0.7.0
GRAFANA_VERSION=12.4.2

# Name of the demo table that the ingest simulator creates on the source cluster
# and the Flink replication job replicates to the sink cluster.
DEMO_TABLE=demo_table

# Discovery interval for the KuduSource diff scan (seconds).
DISCOVERY_INTERVAL_SECONDS=10

# Flink checkpointing interval (milliseconds).
# Must be strictly less than DISCOVERY_INTERVAL_SECONDS * 1000.
CHECKPOINT_INTERVAL_MS=5000

# Ingest simulator settings.
INGEST_INTERVAL=0.2     # seconds between operations (5 ops/sec)
INSERT_RATE=0.4         # relative weight for INSERT ops
UPDATE_RATE=0.2         # relative weight for UPDATE ops
DELETE_RATE=0.15        # relative weight for DELETE ops
UPSERT_RATE=0.25        # relative weight for UPSERT ops

# Flink job parallelism.
# Overrides parallelism.default in the Flink cluster config at submit time.
# Set to 1 to make enumerator split state more visible in Grafana.
FLINK_PARALLELISM=2
